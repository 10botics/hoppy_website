---
import Layout from '../layouts/Layout.astro';
import { getLocalizedPath, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const isTc = lang === 'tc';
const path = (value: string) => getLocalizedPath(value, lang);

const copy = isTc
  ? {
      tagline: '讓學習變得令人上癮',
      description: '與小兔 Hoppy 一起踏上刺激的學習冒險！有趣、互動，專為好奇的小朋友設計。',
      appSmall: '下載於',
      appStore: 'App Store',
      playSmall: '立即下載',
      playStore: 'Google Play',
      subjects: '科目',
      whyTitle: '為什麼選擇 Hoppy？',
      features: [
        ['互動學習', '引人入勝的活動，讓學習變得有趣且難忘。', '視'],
        ['創意玩樂', '色彩繽紛、充滿童趣的設計，激發好奇心和想像力。', '適'],
        ['進度追蹤', '見證孩子的成長，慶祝每一個成就。', '進'],
      ],
      widgetTag: '科目內容',
      widgetTitle: '把抽象概念變成看得見的題目',
      widgetText: 'Hoppy 把圖表、方程式、電路、化學反應和立體圖形直接融入練習，幫助學生真正理解概念。',
      widgetButton: '查看所有科目',
      widgetItems: [
        ['互動時鐘', '用可視化時鐘練習時間概念', '/widgets/widget_analogclock.svg', '/subjects/mathematics'],
        ['圖表與數據', '從圖表中閱讀和理解數據', '/widgets/widget_barchart.svg', '/subjects/mathematics'],
        ['函數與方程', '把數學關係轉化為清晰圖像', '/widgets/widget_equationgraph_parabola.svg', '/subjects/mathematics'],
        ['電路', '直接在題目中觀察電路結構', '/widgets/widget_circuit.svg', '/subjects/physics'],
        ['化學方程式', '以清晰格式呈現化學反應', '/widgets/widget_chemicalequation.svg', '/subjects/chemistry'],
        ['立體圖形', '從不同角度理解立體幾何', '/widgets/widget_shape3d_cube.svg', '/subjects/mathematics'],
      ],
      reviewTag: '家長及老師功能',
      reviewTitle: '家長和老師可查看學生答錯的題目',
      reviewText: '清楚查看學生答錯的每一道題目，了解他們在哪些課題需要更多練習，並給予更合適的幫助。',
      reviewPoints: ['查看每一道答錯的題目', '了解需要加強的課題', '見證進步並慶祝成就'],
      reviewImageAlt: 'Hoppy 題目作答畫面，顯示學生的答案、正確答案及解釋',
      adaptiveTag: '自適應學習現已推出',
      adaptiveTitle: '量度你的學習旅程',
      adaptiveText: 'Hoppy 會按照學生的程度調整練習，並幫助你追蹤每一步的進度！我們將一起量度成就，慶祝學習旅程中的每個里程碑。',
      adaptivePoints: ['按照作答情況調整練習', '支援不同學習程度', '清楚記錄學習進度'],
      classroomTag: '學校及老師',
      classroomTitle: '把 Hoppy 帶進 Google Classroom',
      classroomText: '老師可透過 Google Classroom 發佈 Hoppy 練習指示及下載連結，學生在 Hoppy 完成互動練習，再按學習表現安排跟進。',
      classroomSteps: ['在 Classroom 發佈練習', '學生使用 Hoppy 完成', '按學習結果安排跟進'],
      audienceTitle: '適合每一位參與學習的人',
      audiences: [
        ['學生', '透過互動題目，以適合自己的程度和步伐持續練習。'],
        ['老師', '利用清晰的視覺內容，協助講解較難單靠文字表達的概念。'],
        ['家長', '透過進度追蹤及多個學習者檔案，了解孩子的學習旅程。'],
      ],
      pricingTitle: '尋找適合你的學習方案',
      pricingText: '由輕鬆開始到更密集的日常練習，按需要選擇方案。',
      pricingButton: '查看方案與收費',
      ctaTitle: '準備好開始跳躍了嗎？',
      ctaText: '加入數以千計正在與 Hoppy 一起學習的小朋友。',
    }
  : {
      tagline: 'Learning becomes addictive',
      description: 'Join Hoppy the bunny on an exciting learning adventure! Fun, interactive, and designed specifically for curious young minds.',
      appSmall: 'Download on the',
      appStore: 'App Store',
      playSmall: 'GET IT ON',
      playStore: 'Google Play',
      subjects: 'Subjects',
      whyTitle: 'Why Choose Hoppy?',
      features: [
        ['Interactive Learning', 'Engaging activities that make learning fun and memorable.', 'V'],
        ['Creative Play', 'Colorful, playful design that sparks curiosity and imagination.', 'A'],
        ['Progress Tracking', 'Watch your child grow and celebrate their achievements.', 'P'],
      ],
      widgetTag: 'Interactive questions',
      widgetTitle: 'Turn abstract concepts into questions students can see',
      widgetText: 'Hoppy brings charts, equations, circuits, chemical reactions and 3D shapes directly into practice so students can truly understand each concept.',
      widgetButton: 'View all subjects',
      widgetItems: [
        ['Interactive clocks', 'Practise time concepts with visual clocks', '/widgets/widget_analogclock.svg', '/subjects/mathematics'],
        ['Charts and data', 'Read and understand data through charts', '/widgets/widget_barchart.svg', '/subjects/mathematics'],
        ['Functions and equations', 'Turn mathematical relationships into clear visuals', '/widgets/widget_equationgraph_parabola.svg', '/subjects/mathematics'],
        ['Electric circuits', 'See circuit structures directly in each question', '/widgets/widget_circuit.svg', '/subjects/physics'],
        ['Chemical equations', 'Present chemical reactions in a clear format', '/widgets/widget_chemicalequation.svg', '/subjects/chemistry'],
        ['3D shapes', 'Understand solid geometry from different angles', '/widgets/widget_shape3d_cube.svg', '/subjects/mathematics'],
      ],
      reviewTag: 'For parents and teachers',
      reviewTitle: 'Parents and teachers can see which questions students got wrong',
      reviewText: 'Review every question a student answered incorrectly, understand which topics need more practice, and provide more suitable support.',
      reviewPoints: ['Review every incorrect question', 'Identify topics that need more practice', 'Watch progress and celebrate achievements'],
      reviewImageAlt: 'Hoppy quiz screen showing a student answer, the correct answer and an explanation',
      adaptiveTag: 'Adaptive learning is live',
      adaptiveTitle: 'Measure Your Learning Journey',
      adaptiveText: 'Hoppy adapts practice to each student’s level and helps track progress with every hop! Together, we’ll measure achievements and celebrate milestones in the learning adventure.',
      adaptivePoints: ['Adjusts practice from student answers', 'Supports different learning levels', 'Makes learning progress visible'],
      classroomTag: 'For schools and teachers',
      classroomTitle: 'Bring Hoppy into Google Classroom',
      classroomText: 'Teachers can use Google Classroom to post Hoppy practice instructions and download links. Students complete interactive practice in Hoppy, then teachers use the learning results to plan follow-up support.',
      classroomSteps: ['Post practice in Classroom', 'Students complete it in Hoppy', 'Plan follow-up from the results'],
      audienceTitle: 'Made for everyone involved in learning',
      audiences: [
        ['Students', 'Practise with interactive questions at a level and pace that fits.'],
        ['Teachers', 'Use clear visual question formats to explain ideas that are difficult to show with words alone.'],
        ['Parents', 'Follow the learning journey through progress tracking and multiple learner profiles.'],
      ],
      pricingTitle: 'Find the learning plan that fits',
      pricingText: 'From an easy start to more intensive daily practice, choose according to your needs.',
      pricingButton: 'View plans and pricing',
      ctaTitle: 'Ready to Start Hopping?',
      ctaText: 'Join thousands of kids already learning with Hoppy.',
    };
---

<Layout lang={lang}>
  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="tagline">{copy.tagline}</p>
          <h1 class="wordmark">H<span>o</span>ppy</h1>
          <p class="hero-description">{copy.description}</p>

          <div class="store-buttons">
            <a class="store-button" href="https://apps.apple.com/hk/app/hoppy-learn-10x-faster/id6754865277" target="_blank" rel="noopener noreferrer">
              <img src="/apple-logo.svg" alt="" class="store-brand-icon" aria-hidden="true" />
              <span><small>{copy.appSmall}</small><strong>{copy.appStore}</strong></span>
            </a>
            <a class="store-button" href="https://play.google.com/store/apps/details?id=day.hoppy.app" target="_blank" rel="noopener noreferrer">
              <span class="store-mark play">▶</span>
              <span><small>{copy.playSmall}</small><strong>{copy.playStore}</strong></span>
            </a>
          </div>

          <a href={path('/subjects')} class="secondary-button">{copy.subjects}</a>
        </div>

        <div class="hero-image-wrap">
          <img src="/unnamed (2).png" alt="Hoppy" class="hero-image" />
        </div>
      </div>
    </section>

    <section class="features section">
      <div class="container">
        <h2>{copy.whyTitle}</h2>
        <div class="feature-grid">
          {copy.features.map((feature) => (
            <article class="feature-card">
              <span class="feature-icon">{feature[2]}</span>
              <h3>{feature[0]}</h3>
              <p>{feature[1]}</p>
            </article>
          ))}
        </div>

        <div class="widget-showcase">
          <div class="widget-heading">
            <div>
              <span class="small-tag">{copy.widgetTag}</span>
              <h3>{copy.widgetTitle}</h3>
              <p>{copy.widgetText}</p>
            </div>
            <a href={path('/subjects')} class="widget-link">{copy.widgetButton} <span aria-hidden="true">→</span></a>
          </div>

          <div class="widget-gallery">
            {copy.widgetItems.map((item) => (
              <a href={path(item[3])} class="widget-photo-card">
                <div class="widget-photo-wrap">
                  <img src={item[2]} alt={item[0]} loading="lazy" />
                </div>
                <div class="widget-photo-copy">
                  <h4>{item[0]}</h4>
                  <p>{item[1]}</p>
                </div>
              </a>
            ))}
          </div>
        </div>

        <article class="review-highlight">
          <div class="review-copy">
            <span class="small-tag review-tag">{copy.reviewTag}</span>
            <h3>{copy.reviewTitle}</h3>
            <p>{copy.reviewText}</p>
            <ul>
              {copy.reviewPoints.map((point) => <li>{point}</li>)}
            </ul>
          </div>

          <div class="review-photo">
            <img
              src="/student-wrong-question-review.png"
              alt={copy.reviewImageAlt}
              loading="lazy"
            />
          </div>
        </article>
      </div>
    </section>

    <section class="adaptive section">
      <div class="container adaptive-card">
        <div class="adaptive-image-wrap">
          <img src="/hoppy-ruler.jpeg" alt="Hoppy with ruler" loading="lazy" />
        </div>
        <div class="adaptive-copy">
          <span class="small-tag">{copy.adaptiveTag}</span>
          <h2>{copy.adaptiveTitle}</h2>
          <p>{copy.adaptiveText}</p>
          <ul>
            {copy.adaptivePoints.map((point) => <li>{point}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="classroom section">
      <div class="container classroom-card">
        <div class="classroom-copy">
          <span class="small-tag">{copy.classroomTag}</span>
          <h2>{copy.classroomTitle}</h2>
          <p>{copy.classroomText}</p>
        </div>

        <div class="classroom-flow" aria-label={copy.classroomTitle}>
          {copy.classroomSteps.map((step, index) => (
            <div class="classroom-step">
              <span>{index + 1}</span>
              <strong>{step}</strong>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="audience section">
      <div class="container">
        <h2>{copy.audienceTitle}</h2>
        <div class="audience-grid">
          {copy.audiences.map((audience) => (
            <article class="audience-card">
              <h3>{audience[0]}</h3>
              <p>{audience[1]}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="pricing-strip">
      <div class="container pricing-content">
        <div>
          <h2>{copy.pricingTitle}</h2>
          <p>{copy.pricingText}</p>
        </div>
        <a href={path('/pricing')} class="pricing-button">{copy.pricingButton}</a>
      </div>
    </section>

    <section class="final-cta">
      <div class="container cta-content">
        <img src="/hoppy-logo.jpeg" alt="Hoppy" loading="lazy" />
        <h2>{copy.ctaTitle}</h2>
        <p>{copy.ctaText}</p>
        <div class="store-buttons store-buttons-centered">
          <a class="store-button store-button-light" href="https://apps.apple.com/hk/app/hoppy-learn-10x-faster/id6754865277" target="_blank" rel="noopener noreferrer">
            <img src="/apple-logo.svg" alt="" class="store-brand-icon" aria-hidden="true" />
            <span><small>{copy.appSmall}</small><strong>{copy.appStore}</strong></span>
          </a>
          <a class="store-button store-button-light" href="https://play.google.com/store/apps/details?id=day.hoppy.app" target="_blank" rel="noopener noreferrer">
            <span class="store-mark play">▶</span>
            <span><small>{copy.playSmall}</small><strong>{copy.playStore}</strong></span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    overflow-x: hidden;
  }

  .container {
    width: min(1120px, calc(100% - 3rem));
    margin-inline: auto;
  }

  .section {
    padding-block: 5rem;
  }

  .hero {
    min-height: 720px;
    display: flex;
    align-items: center;
    padding-block: 4rem;
    background: linear-gradient(135deg, var(--hoppy-gray) 0%, #e7eaed 100%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: 4.5rem;
    align-items: center;
  }

  .tagline {
    margin: 0 0 1rem;
    color: var(--hoppy-navy);
    font-size: 1.15rem;
    font-weight: 600;
  }

  .wordmark {
    margin: 0;
    font-size: clamp(4.2rem, 8vw, 6.5rem);
    font-weight: 800;
    letter-spacing: -0.055em;
    line-height: 1;
  }

  .wordmark span {
    color: var(--hoppy-blue);
    font-style: italic;
  }

  .hero-description {
    max-width: 610px;
    margin: 1.6rem 0 0;
    color: #4f6678;
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .hero-image-wrap {
    display: flex;
    justify-content: center;
  }

  .hero-image {
    width: min(100%, 460px);
    border-radius: 24px;
    box-shadow: 0 22px 55px rgba(26, 49, 68, 0.16);
  }

  .store-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2rem;
  }

  .store-button {
    min-width: 175px;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.72rem 1rem;
    border-radius: 12px;
    background: #050505;
    color: white;
    text-align: left;
    text-decoration: none;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .store-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.2);
  }

  .store-button > span:last-child {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .store-button small {
    font-size: 0.62rem;
  }

  .store-button strong {
    font-size: 1.03rem;
  }

  .store-mark {
    width: 25px;
    font-size: 1.5rem;
    text-align: center;
  }

  .store-brand-icon {
    width: 25px;
    height: 30px;
    flex: 0 0 25px;
    object-fit: contain;
  }

  .store-button:not(.store-button-light) .store-brand-icon {
    filter: invert(1);
  }

  .store-mark.play {
    font-size: 1.1rem;
  }

  .secondary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.2rem;
    padding: 0.82rem 1.4rem;
    border-radius: 999px;
    background: var(--hoppy-navy);
    color: white;
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
  }

  .features {
    background: #f8f9fa;
    text-align: center;
  }

  .features h2,
  .audience h2 {
    margin: 0 0 2.7rem;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    padding: 2.3rem 1.8rem;
    border: 1px solid #e2e8ec;
    border-radius: 20px;
    background: white;
    box-shadow: 0 10px 30px rgba(26, 49, 68, 0.05);
  }

  .feature-icon {
    width: 58px;
    height: 58px;
    display: inline-grid;
    place-items: center;
    border-radius: 17px;
    background: #e3f6fc;
    color: #168fb7;
    font-size: 1.2rem;
    font-weight: 800;
  }

  .feature-card h3 {
    margin: 1.25rem 0 0.8rem;
    font-size: 1.35rem;
  }

  .feature-card p,
  .audience-card p {
    margin: 0;
    color: #607486;
    font-size: 0.95rem;
    line-height: 1.75;
  }

  .widget-showcase {
    margin-top: 4.5rem;
    text-align: left;
  }

  .widget-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 1.8rem;
  }

  .widget-heading h3 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(1.8rem, 3.5vw, 2.65rem);
    line-height: 1.18;
  }

  .widget-heading p {
    max-width: 760px;
    margin: 0.9rem 0 0;
    color: #607486;
    font-size: 0.98rem;
    line-height: 1.75;
  }

  .widget-link {
    flex: 0 0 auto;
    padding-bottom: 0.25rem;
    color: #168fb7;
    font-size: 0.9rem;
    font-weight: 750;
    text-decoration: none;
  }

  .widget-link:hover {
    text-decoration: underline;
  }

  .widget-gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .widget-photo-card {
    overflow: hidden;
    border: 1px solid #dce6eb;
    border-radius: 18px;
    background: white;
    color: var(--hoppy-navy);
    text-decoration: none;
    box-shadow: 0 10px 28px rgba(26, 49, 68, 0.06);
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .widget-photo-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 34px rgba(26, 49, 68, 0.12);
  }

  .widget-photo-wrap {
    height: 320px;
    display: grid;
    place-items: center;
    overflow: hidden;
    padding: 1.5rem;
    border-bottom: 1px solid #e4ebef;
    background: linear-gradient(145deg, #f7fbfd 0%, #eaf5f9 100%);
  }

  .widget-photo-wrap img {
    display: block;
    width: auto;
    height: auto;
    max-width: 88%;
    max-height: 250px;
    object-fit: contain;
    object-position: center;
  }

  .widget-photo-copy {
    padding: 1.3rem 1.4rem 1.4rem;
  }

  .widget-photo-copy h4 {
    margin: 0;
    font-size: 1.22rem;
  }

  .widget-photo-copy p {
    margin: 0.45rem 0 0;
    color: #63798a;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .review-highlight {
    display: grid;
    grid-template-columns: 1fr 0.95fr;
    gap: 3rem;
    align-items: center;
    margin-top: 1.5rem;
    padding: 2.6rem;
    border: 1px solid #cfe6ee;
    border-radius: 24px;
    background: linear-gradient(135deg, #eef9fc 0%, #f8fbfc 100%);
    text-align: left;
  }

  .review-tag {
    margin-bottom: 0.9rem;
  }

  .review-copy h3 {
    margin: 0;
    font-size: clamp(1.65rem, 3vw, 2.35rem);
  }

  .review-copy > p {
    margin: 1rem 0 0;
    color: #5b7182;
    font-size: 0.98rem;
    line-height: 1.75;
  }

  .review-copy ul {
    display: grid;
    gap: 0.55rem;
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .review-copy li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--hoppy-navy);
    font-size: 0.9rem;
    font-weight: 650;
  }

  .review-copy li::before {
    width: 8px;
    height: 8px;
    flex: 0 0 8px;
    border-radius: 50%;
    background: var(--hoppy-blue);
    content: '';
  }

  .review-photo {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .review-photo img {
    display: block;
    width: auto;
    max-width: 100%;
    max-height: 560px;
    border: 1px solid #dce7ec;
    border-radius: 22px;
    background: white;
    box-shadow: 0 18px 42px rgba(26, 49, 68, 0.14);
  }

  .adaptive {
    background: white;
  }

  .adaptive-card {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 4rem;
    align-items: center;
    padding: 2.5rem;
    border-radius: 28px;
    background: #f5f8fa;
  }

  .adaptive-image-wrap img {
    width: 100%;
    border-radius: 20px;
    box-shadow: 0 15px 35px rgba(26, 49, 68, 0.1);
  }

  .small-tag {
    display: inline-block;
    margin-bottom: 0.8rem;
    padding: 0.38rem 0.75rem;
    border-radius: 999px;
    background: #dcf4fb;
    color: #147fa2;
    font-size: 0.75rem;
    font-weight: 800;
  }

  .adaptive-copy h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .adaptive-copy > p {
    margin: 1.1rem 0 0;
    color: #5c7182;
    font-size: 1rem;
    line-height: 1.8;
  }

  .adaptive-copy ul {
    display: grid;
