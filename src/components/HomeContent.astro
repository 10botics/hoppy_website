---
import Layout from '../layouts/Layout.astro';
import { getLocalizedPath, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const isTc = lang === 'tc';
const path = (value: string) => getLocalizedPath(value, lang);

const copy = isTc
  ? {
      tagline: '讓學習變得令人上癮',
      description: '與小兔 Hoppy 一起踏上刺激的學習冒險！有趣、互動，專為好奇的小朋友設計。',
      appSmall: '下載於',
      appStore: 'App Store',
      playSmall: '立即下載',
      playStore: 'Google Play',
      questionTypes: '支援的題目類型',
      whyTitle: '為什麼選擇 Hoppy？',
      features: [
        ['互動學習', '引人入勝的活動，讓學習變得有趣且難忘。', '視'],
        ['創意玩樂', '色彩繽紛、充滿童趣的設計，激發好奇心和想像力。', '適'],
        ['進度追蹤', '見證孩子的成長，慶祝每一個成就。', '進'],
      ],
      reviewTag: '進度追蹤',
      reviewTitle: '清楚了解孩子答錯的題目',
      reviewText: '家長和老師可以查看學生答錯的每一道題目，找出需要加強的課題，並陪伴他們逐步進步。',
      reviewPoints: ['查看每一道答錯的題目', '了解需要加強的課題', '見證進步並慶祝成就'],
      reviewPanelTitle: '需要溫習的題目',
      reviewSubjects: [['數學', '聯立方程'], ['物理', '電路'], ['化學', '化學方程式']],
      reviewAction: '再次練習',
      adaptiveTag: '自適應學習現已推出',
      adaptiveTitle: '量度你的學習旅程',
      adaptiveText: 'Hoppy 會按照學生的程度調整練習，並幫助你追蹤每一步的進度！我們將一起量度成就，慶祝學習旅程中的每個里程碑。',
      adaptivePoints: ['按照作答情況調整練習', '支援不同學習程度', '清楚記錄學習進度'],
      audienceTitle: '適合每一位參與學習的人',
      audiences: [
        ['學生', '透過互動題目，以適合自己的程度和步伐持續練習。'],
        ['老師', '利用清晰的視覺題型，協助講解較難單靠文字表達的概念。'],
        ['家長', '透過進度追蹤及多個學習者檔案，了解孩子的學習旅程。'],
      ],
      pricingTitle: '尋找適合你的學習方案',
      pricingText: '由輕鬆開始到更密集的日常練習，按需要選擇方案。',
      pricingButton: '查看方案與收費',
      ctaTitle: '準備好開始跳躍了嗎？',
      ctaText: '加入數以千計正在與 Hoppy 一起學習的小朋友。',
    }
  : {
      tagline: 'Learning becomes addictive',
      description: 'Join Hoppy the bunny on an exciting learning adventure! Fun, interactive, and designed specifically for curious young minds.',
      appSmall: 'Download on the',
      appStore: 'App Store',
      playSmall: 'GET IT ON',
      playStore: 'Google Play',
      questionTypes: 'Supported Widgets',
      whyTitle: 'Why Choose Hoppy?',
      features: [
        ['Interactive Learning', 'Engaging activities that make learning fun and memorable.', 'V'],
        ['Creative Play', 'Colorful, playful design that sparks curiosity and imagination.', 'A'],
        ['Progress Tracking', 'Watch your child grow and celebrate their achievements.', 'P'],
      ],
      reviewTag: 'Progress Tracking',
      reviewTitle: 'See which questions need another look',
      reviewText: 'Parents and teachers can review every question a student answered incorrectly, identify areas that need more support, and celebrate progress along the way.',
      reviewPoints: ['Review every incorrect question', 'Identify topics that need more practice', 'Watch progress and celebrate achievements'],
      reviewPanelTitle: 'Questions to revisit',
      reviewSubjects: [['Mathematics', 'Simultaneous equations'], ['Physics', 'Electric circuits'], ['Chemistry', 'Chemical equations']],
      reviewAction: 'Practise again',
      adaptiveTag: 'Adaptive learning is live',
      adaptiveTitle: 'Measure Your Learning Journey',
      adaptiveText: 'Hoppy adapts practice to each student’s level and helps track progress with every hop! Together, we’ll measure achievements and celebrate milestones in the learning adventure.',
      adaptivePoints: ['Adjusts practice from student answers', 'Supports different learning levels', 'Makes learning progress visible'],
      audienceTitle: 'Made for everyone involved in learning',
      audiences: [
        ['Students', 'Practise with interactive questions at a level and pace that fits.'],
        ['Teachers', 'Use clear visual question formats to explain ideas that are difficult to show with words alone.'],
        ['Parents', 'Follow the learning journey through progress tracking and multiple learner profiles.'],
      ],
      pricingTitle: 'Find the learning plan that fits',
      pricingText: 'From an easy start to more intensive daily practice, choose according to your needs.',
      pricingButton: 'View plans and pricing',
      ctaTitle: 'Ready to Start Hopping?',
      ctaText: 'Join thousands of kids already learning with Hoppy.',
    };
---

<Layout lang={lang}>
  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="tagline">{copy.tagline}</p>
          <h1 class="wordmark">H<span>o</span>ppy</h1>
          <p class="hero-description">{copy.description}</p>

          <div class="store-buttons">
            <a class="store-button" href="https://apps.apple.com/hk/app/hoppy-learn-10x-faster/id6754865277" target="_blank" rel="noopener noreferrer">
              <span class="store-mark">●</span>
              <span><small>{copy.appSmall}</small><strong>{copy.appStore}</strong></span>
            </a>
            <a class="store-button" href="https://play.google.com/store/apps/details?id=day.hoppy.app" target="_blank" rel="noopener noreferrer">
              <span class="store-mark play">▶</span>
              <span><small>{copy.playSmall}</small><strong>{copy.playStore}</strong></span>
            </a>
          </div>

          <a href={path('/supported-question-images')} class="secondary-button">{copy.questionTypes}</a>
        </div>

        <div class="hero-image-wrap">
          <img src="/unnamed (2).png" alt="Hoppy" class="hero-image" />
        </div>
      </div>
    </section>

    <section class="features section">
      <div class="container">
        <h2>{copy.whyTitle}</h2>
        <div class="feature-grid">
          {copy.features.map((feature) => (
            <article class="feature-card">
              <span class="feature-icon">{feature[2]}</span>
              <h3>{feature[0]}</h3>
              <p>{feature[1]}</p>
            </article>
          ))}
        </div>

        <article class="review-highlight">
          <div class="review-copy">
            <span class="small-tag review-tag">{copy.reviewTag}</span>
            <h3>{copy.reviewTitle}</h3>
            <p>{copy.reviewText}</p>
            <ul>
              {copy.reviewPoints.map((point) => <li>{point}</li>)}
            </ul>
          </div>

          <div class="review-panel" aria-label={copy.reviewPanelTitle}>
            <div class="review-panel-header">
              <span>{copy.reviewPanelTitle}</span>
              <strong>3</strong>
            </div>
            <div class="review-list">
              {copy.reviewSubjects.map((item, index) => (
                <div class="review-row">
                  <span class="wrong-mark">{index + 1}</span>
                  <div>
                    <strong>{item[0]}</strong>
                    <small>{item[1]}</small>
                  </div>
                  <span class="review-action">{copy.reviewAction}</span>
                </div>
              ))}
            </div>
          </div>
        </article>
      </div>
    </section>

    <section class="adaptive section">
      <div class="container adaptive-card">
        <div class="adaptive-image-wrap">
          <img src="/hoppy-ruler.jpeg" alt="Hoppy with ruler" loading="lazy" />
        </div>
        <div class="adaptive-copy">
          <span class="small-tag">{copy.adaptiveTag}</span>
          <h2>{copy.adaptiveTitle}</h2>
          <p>{copy.adaptiveText}</p>
          <ul>
            {copy.adaptivePoints.map((point) => <li>{point}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="audience section">
      <div class="container">
        <h2>{copy.audienceTitle}</h2>
        <div class="audience-grid">
          {copy.audiences.map((audience) => (
            <article class="audience-card">
              <h3>{audience[0]}</h3>
              <p>{audience[1]}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="pricing-strip">
      <div class="container pricing-content">
        <div>
          <h2>{copy.pricingTitle}</h2>
          <p>{copy.pricingText}</p>
        </div>
        <a href={path('/pricing')} class="pricing-button">{copy.pricingButton}</a>
      </div>
    </section>

    <section class="final-cta">
      <div class="container cta-content">
        <img src="/hoppy-logo.jpeg" alt="Hoppy" loading="lazy" />
        <h2>{copy.ctaTitle}</h2>
        <p>{copy.ctaText}</p>
        <div class="store-buttons store-buttons-centered">
          <a class="store-button store-button-light" href="https://apps.apple.com/hk/app/hoppy-learn-10x-faster/id6754865277" target="_blank" rel="noopener noreferrer">
            <span class="store-mark">●</span>
            <span><small>{copy.appSmall}</small><strong>{copy.appStore}</strong></span>
          </a>
          <a class="store-button store-button-light" href="https://play.google.com/store/apps/details?id=day.hoppy.app" target="_blank" rel="noopener noreferrer">
            <span class="store-mark play">▶</span>
            <span><small>{copy.playSmall}</small><strong>{copy.playStore}</strong></span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    overflow-x: hidden;
  }

  .container {
    width: min(1120px, calc(100% - 3rem));
    margin-inline: auto;
  }

  .section {
    padding-block: 5rem;
  }

  .hero {
    min-height: 720px;
    display: flex;
    align-items: center;
    padding-block: 4rem;
    background: linear-gradient(135deg, var(--hoppy-gray) 0%, #e7eaed 100%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: 4.5rem;
    align-items: center;
  }

  .tagline {
    margin: 0 0 1rem;
    color: var(--hoppy-navy);
    font-size: 1.15rem;
    font-weight: 600;
  }

  .wordmark {
    margin: 0;
    font-size: clamp(4.2rem, 8vw, 6.5rem);
    font-weight: 800;
    letter-spacing: -0.055em;
    line-height: 1;
  }

  .wordmark span {
    color: var(--hoppy-blue);
    font-style: italic;
  }

  .hero-description {
    max-width: 610px;
    margin: 1.6rem 0 0;
    color: #4f6678;
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .hero-image-wrap {
    display: flex;
    justify-content: center;
  }

  .hero-image {
    width: min(100%, 460px);
    border-radius: 24px;
    box-shadow: 0 22px 55px rgba(26, 49, 68, 0.16);
  }

  .store-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2rem;
  }

  .store-button {
    min-width: 175px;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.72rem 1rem;
    border-radius: 12px;
    background: #050505;
    color: white;
    text-align: left;
    text-decoration: none;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .store-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.2);
  }

  .store-button > span:last-child {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .store-button small {
    font-size: 0.62rem;
  }

  .store-button strong {
    font-size: 1.03rem;
  }

  .store-mark {
    width: 25px;
    font-size: 1.5rem;
    text-align: center;
  }

  .store-mark.play {
    font-size: 1.1rem;
  }

  .secondary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.2rem;
    padding: 0.82rem 1.4rem;
    border-radius: 999px;
    background: var(--hoppy-navy);
    color: white;
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
  }

  .features {
    background: #f8f9fa;
    text-align: center;
  }

  .features h2,
  .audience h2 {
    margin: 0 0 2.7rem;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    padding: 2.3rem 1.8rem;
    border: 1px solid #e2e8ec;
    border-radius: 20px;
    background: white;
    box-shadow: 0 10px 30px rgba(26, 49, 68, 0.05);
  }

  .feature-icon {
    width: 58px;
    height: 58px;
    display: inline-grid;
    place-items: center;
    border-radius: 17px;
    background: #e3f6fc;
    color: #168fb7;
    font-size: 1.2rem;
    font-weight: 800;
  }

  .feature-card h3 {
    margin: 1.25rem 0 0.8rem;
    font-size: 1.35rem;
  }

  .feature-card p,
  .audience-card p {
    margin: 0;
    color: #607486;
    font-size: 0.95rem;
    line-height: 1.75;
  }

  .review-highlight {
    display: grid;
    grid-template-columns: 1fr 0.95fr;
    gap: 3rem;
    align-items: center;
    margin-top: 1.5rem;
    padding: 2.6rem;
    border: 1px solid #cfe6ee;
    border-radius: 24px;
    background: linear-gradient(135deg, #eef9fc 0%, #f8fbfc 100%);
    text-align: left;
  }

  .review-tag {
    margin-bottom: 0.9rem;
  }

  .review-copy h3 {
    margin: 0;
    font-size: clamp(1.65rem, 3vw, 2.35rem);
  }

  .review-copy > p {
    margin: 1rem 0 0;
    color: #5b7182;
    font-size: 0.98rem;
    line-height: 1.75;
  }

  .review-copy ul {
    display: grid;
    gap: 0.55rem;
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .review-copy li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--hoppy-navy);
    font-size: 0.9rem;
    font-weight: 650;
  }

  .review-copy li::before {
    width: 8px;
    height: 8px;
    flex: 0 0 8px;
    border-radius: 50%;
    background: var(--hoppy-blue);
    content: '';
  }

  .review-panel {
    overflow: hidden;
    border: 1px solid #dce7ec;
    border-radius: 18px;
    background: white;
    box-shadow: 0 14px 35px rgba(26, 49, 68, 0.09);
  }

  .review-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.15rem;
    border-bottom: 1px solid #e8eef1;
    color: var(--hoppy-navy);
    font-size: 0.88rem;
    font-weight: 750;
  }

  .review-panel-header strong {
    display: grid;
    place-items: center;
    width: 27px;
    height: 27px;
    border-radius: 50%;
    background: #fee9e7;
    color: #bd4a40;
    font-size: 0.75rem;
  }

  .review-list {
    display: grid;
  }

  .review-row {
    display: grid;
    grid-template-columns: 32px 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding: 0.95rem 1.1rem;
  }

  .review-row + .review-row {
    border-top: 1px solid #eef2f4;
  }

  .wrong-mark {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 9px;
    background: #fee9e7;
    color: #bd4a40;
    font-size: 0.72rem;
    font-weight: 800;
  }

  .review-row > div {
    display: flex;
    min-width: 0;
    flex-direction: column;
  }

  .review-row strong {
    font-size: 0.86rem;
  }

  .review-row small {
    overflow: hidden;
    color: #718492;
    font-size: 0.72rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .review-action {
    color: #168fb7;
    font-size: 0.72rem;
    font-weight: 750;
  }

  .adaptive {
    background: white;
  }

  .adaptive-card {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 4rem;
    align-items: center;
    padding: 2.5rem;
    border-radius: 28px;
    background: #f5f8fa;
  }

  .adaptive-image-wrap img {
    width: 100%;
    border-radius: 20px;
    box-shadow: 0 15px 35px rgba(26, 49, 68, 0.1);
  }

  .small-tag {
    display: inline-block;
    margin-bottom: 0.8rem;
    padding: 0.38rem 0.75rem;
    border-radius: 999px;
    background: #dcf4fb;
    color: #147fa2;
    font-size: 0.75rem;
    font-weight: 800;
  }

  .adaptive-copy h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .adaptive-copy > p {
    margin: 1.1rem 0 0;
    color: #5c7182;
    font-size: 1rem;
    line-height: 1.8;
  }

  .adaptive-copy ul {
    display: grid;
    gap: 0.7rem;
    margin: 1.4rem 0 0;
    padding: 0;
    list-style: none;
  }

  .adaptive-copy li {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--hoppy-navy);
    font-size: 0.92rem;
    font-weight: 650;
  }

  .adaptive-copy li::before {
    width: 20px;
    height: 20px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--hoppy-blue);
    color: white;
    content: '✓';
    font-size: 0.7rem;
  }

  .audience {
    background: #f8f9fa;
    text-align: center;
  }

  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }

  .audience-card {
    padding: 2rem 1.6rem;
    border: 1px solid #dde7ec;
    border-radius: 18px;
    background: white;
  }

  .audience-card h3 {
    margin: 0 0 0.7rem;
    color: #168fb7;
    font-size: 1.35rem;
  }

  .pricing-strip {
    padding-block: 3.2rem;
    background: var(--hoppy-navy);
    color: white;
  }

  .pricing-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .pricing-content h2 {
    margin: 0;
    color: white;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
  }

  .pricing-content p {
    margin: 0.65rem 0 0;
    color: #c7d6df;
    font-size: 0.95rem;
  }

  .pricing-button {
    flex: 0 0 auto;
    padding: 0.85rem 1.35rem;
    border-radius: 999px;
    background: white;
    color: var(--hoppy-navy);
    font-size: 0.9rem;
    font-weight: 750;
    text-decoration: none;
  }

  .final-cta {
    padding-block: 5rem;
    background: linear-gradient(135deg, var(--hoppy-blue), #35a3c9);
    color: white;
    text-align: center;
  }

  .cta-content {
    display: grid;
    justify-items: center;
  }

  .cta-content > img {
    width: 150px;
    margin-bottom: 1.5rem;
    padding: 0.7rem;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.16);
  }

  .cta-content h2 {
    margin: 0;
    color: white;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .cta-content > p {
    margin: 0.8rem 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1rem;
  }

  .store-buttons-centered {
    justify-content: center;
  }

  .store-button-light {
    background: white;
    color: var(--hoppy-navy);
  }

  @media (max-width: 820px) {
    .hero {
      min-height: auto;
    }

    .hero-grid,
    .adaptive-card,
    .review-highlight {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      order: 2;
      text-align: center;
    }

    .hero-image-wrap {
      order: 1;
    }

    .store-buttons {
      justify-content: center;
    }

    .feature-grid,
    .audience-grid {
      grid-template-columns: 1fr;
    }

    .pricing-content {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 520px) {
    .container {
      width: calc(100% - 2rem);
    }

    .section {
      padding-block: 3.5rem;
    }

    .hero {
      padding-block: 3rem;
    }

    .hero-grid {
      gap: 2.5rem;
    }

    .wordmark {
      font-size: 4.2rem;
    }

    .store-buttons {
      align-items: center;
      flex-direction: column;
    }

    .store-button {
      width: min(100%, 220px);
    }

    .adaptive-card {
      padding: 1.2rem;
      gap: 2rem;
    }

    .review-highlight {
      padding: 1.25rem;
      gap: 1.6rem;
    }

    .review-row {
      grid-template-columns: 30px 1fr;
    }

    .review-action {
      display: none;
    }
  }
</style>


