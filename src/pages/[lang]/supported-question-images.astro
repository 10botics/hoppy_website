          <div class="screenshot-card">
            <img src={screenshot("/screenshots/screenshot-bar-chart-1.jpeg")} alt="Bar chart temperature question" />
          </div>
        </div>

        <!-- Widget Examples -->
        <div class="subsection-label">{t('widgets.widgetVariations')}</div>
        <div class="widget-examples single-column">
          <div class="widget-card large">
            <img src="/widgets/widget_barchart.svg" alt="Bar Chart Widget" />
            <span class="widget-label">{t('widgets.barChart.quarterlySales')}</span>
          </div>
        </div>
      </div>

      <!-- Stacked Bar Chart -->
      <div class="widget-section">
