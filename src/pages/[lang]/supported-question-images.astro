  {
    id: 'mathematics',
    labelKey: 'widgets.subjectGroups.mathematics.title',
    descriptionKey: 'widgets.subjectGroups.mathematics.description',
    image: '/widgets/widget_equationgraph_parabola.svg',
  },
  {
    id: 'physics',
    labelKey: 'widgets.subjectGroups.physics.title',
    descriptionKey: 'widgets.subjectGroups.physics.description',
    image: '/screenshots/screenshot-field-2.jpg',
