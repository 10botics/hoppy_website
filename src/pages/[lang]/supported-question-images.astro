---

<Layout lang={lang}>
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content">
        <h1>{selectedSubject && currentSubject ? t(`widgets.subjectGroups.${selectedSubject}.pageTitle`) : t('widgets.title')}</h1>
        <p class="hero-description">
          {selectedSubject && currentSubject
            ? t(currentSubject.descriptionKey)
            : t('widgets.description')}
        </p>
      </div>
    </section>

    {selectedSubject ? (
      <SubjectNavigation lang={lang} currentSubject={selectedSubject} />
    ) : (
      <section class="subject-hub" aria-labelledby="subject-hub-title">
        <div class="subject-hub-heading">
          <span>{t('widgets.subjectGroups.browseLabel')}</span>
          <h2 id="subject-hub-title">{t('widgets.subjectGroups.hubTitle')}</h2>
          <p>{t('widgets.subjectGroups.hubDescription')}</p>
        </div>
        <div class="subject-card-grid">
          {subjectGroups.map((subject) => (
            <a class="subject-card" href={`${langPrefix}/subjects/${subject.id}`}>
              <div class="subject-card-image">
                <img
                  src={lang === 'tc' && subject.imageTc ? subject.imageTc : subject.image}
                  alt=""
                />
              </div>
              <div class="subject-card-copy">
                <h3>{t(subject.labelKey)}</h3>
                <p>{t(subject.descriptionKey)}</p>
                <span>{t('widgets.subjectGroups.exploreSubject')} <span aria-hidden="true">→</span></span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Widgets Gallery -->
    {selectedSubject && (
    <section class="widgets-gallery">

      {selectedSubject === 'mathematics' && (<>
      <div class="subject-heading" id="mathematics">
        <span class="subject-heading-kicker">{t('widgets.subjectGroups.subjectLabel')}</span>
        <h2>{t('widgets.subjectGroups.mathematics.title')}</h2>
        <p>{t('widgets.subjectGroups.mathematics.description')}</p>
      </div>

      <!-- Analog Clock -->
