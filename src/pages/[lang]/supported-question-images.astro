          </div>
          <div class="widget-card">
            <img src="/widgets/widget_brokenlinegraph_multi.svg" alt="Broken Line Graph - Multiple Series" />
            <span class="widget-label">{t('widgets.brokenLineGraph.multipleSeries')}</span>
          </div>
        </div>
      </div>

      <!-- Box Whisker Plot -->
      <div class="widget-section">
        <div class="widget-header">
          <div class="widget-icon">📈</div>
          <div class="widget-info">
            <h2>{t('widgets.boxWhisker.title')}</h2>
            <p>{t('widgets.boxWhisker.description')}</p>
          </div>
        </div>

        <!-- Live Screenshots -->
        <div class="subsection-label">{t('widgets.liveExamples')}</div>
        <div class="screenshots-grid">
          <div class="screenshot-card">
            <img src={screenshot("/screenshots/screenshot-box-whisker-1.jpeg")} alt="Box whisker IQR question" />
          </div>
        </div>

        <!-- Widget Examples -->
        <div class="subsection-label">{t('widgets.widgetVariations')}</div>
        <div class="widget-examples single-column">
          <div class="widget-card large">
            <img src="/widgets/widget_boxwhisker.svg" alt="Box Whisker Plot Widget" />
            <span class="widget-label">{t('widgets.boxWhisker.scoreDistribution')}</span>
          </div>
        </div>
      </div>

      <!-- Equation Graph -->
      <div class="widget-section">
        <div class="widget-header">
          <div class="widget-icon">📐</div>
          <div class="widget-info">
            <h2>{t('widgets.equationGraph.title')}</h2>
            <p>{t('widgets.equationGraph.description')}</p>
          </div>
        </div>

        <!-- Live Screenshots -->
        <div class="subsection-label">{t('widgets.liveExamples')}</div>
        <div class="screenshots-grid">
          <div class="screenshot-card">
            <img src={screenshot("/screenshots/screenshot-equation-graph-1.jpeg")} alt="Linear inequality graph" />
          </div>
          <div class="screenshot-card">
            <img src={screenshot("/screenshots/screenshot-equation-graph-3.jpeg")} alt="Simultaneous equations" />
          </div>
          <div class="screenshot-card">
            <img src={screenshot("/screenshots/screenshot-equation-graph-5.jpeg")} alt="Logarithmic functions" />
          </div>
        </div>

        <!-- Widget Examples -->
        <div class="subsection-label">{t('widgets.widgetVariations')}</div>
        <div class="widget-examples three-column">
          <div class="widget-card">
            <img src="/widgets/widget_equationgraph_sin.svg" alt="Sine Graph" />
            <span class="widget-label">sin(x)</span>
          </div>
          <div class="widget-card">
            <img src="/widgets/widget_equationgraph_sincos.svg" alt="Sine and Cosine Graph" />
            <span class="widget-label">sin(x) & cos(x)</span>
          </div>
          <div class="widget-card">
            <img src="/widgets/widget_equationgraph_parabola.svg" alt="Parabola Graph" />
            <span class="widget-label">x²</span>
          </div>
        </div>
      </div>

      <!-- 3D Shapes -->
      <div class="widget-section">
        <div class="widget-header">
