---

<Layout lang={lang}>
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content">
        <h1>{t('widgets.title')}</h1>
        <p class="hero-description">
          {t('widgets.description')}
        </p>
      </div>
    </section>

    <!-- Widgets Gallery -->
    <section class="widgets-gallery">
      
      <!-- Analog Clock -->
      <div class="widget-section">
        <div class="widget-header">
          <div class="widget-icon">🕐</div>
          <div class="widget-info">
            <h2>{t('widgets.analogClock.title')}</h2>
            <p>{t('widgets.analogClock.description')}</p>
          </div>
        </div>
        
        <!-- Live Screenshots -->
        <div class="subsection-label">{t('widgets.liveExamples')}</div>
        <div class="screenshots-grid">
          <div class="screenshot-card">
            <img src={screenshot("/screenshots/screenshot-analog-clock-1.jpeg")} alt="Analog clock selection question" />
          </div>
          <div class="screenshot-card">
            <img src={screenshot("/screenshots/screenshot-analog-clock-3.jpeg")} alt="Analog to digital clock conversion" />
          </div>
        </div>

        <!-- Widget Examples -->
        <div class="subsection-label">{t('widgets.widgetVariations')}</div>
        <div class="widget-examples two-column">
          <div class="widget-card">
            <img src="/widgets/widget_analogclock.svg" alt="Analog Clock without seconds" />
            <span class="widget-label">{t('widgets.analogClock.withoutSecondHand')}</span>
          </div>
          <div class="widget-card">
            <img src="/widgets/widget_analogclock_seconds.svg" alt="Analog Clock with seconds" />
            <span class="widget-label">{t('widgets.analogClock.withSecondHand')}</span>
          </div>
        </div>
      </div>

      <!-- Digital Clock -->
      <div class="widget-section">
        <div class="widget-header">
          <div class="widget-icon">⏰</div>
          <div class="widget-info">
            <h2>{t('widgets.digitalClock.title')}</h2>
            <p>{t('widgets.digitalClock.description')}</p>
          </div>
        </div>

        <!-- Live Screenshots -->
        <div class="subsection-label">{t('widgets.liveExamples')}</div>
        <div class="screenshots-grid">
          <div class="screenshot-card">
            <img src={screenshot("/screenshots/screenshot-digital-clock-1.jpeg")} alt="Digital clock multiple choice question" />
          </div>
        </div>

        <!-- Widget Examples -->
        <div class="subsection-label">{t('widgets.widgetVariations')}</div>
        <div class="widget-examples two-column">
          <div class="widget-card dark-bg">
            <img src="/widgets/widget_digitalclock_12h.svg" alt="Digital Clock 12-hour format" />
            <span class="widget-label">{t('widgets.digitalClock.format12')}</span>
          </div>
          <div class="widget-card dark-bg">
            <img src="/widgets/widget_digitalclock_24h.svg" alt="Digital Clock 24-hour format" />
            <span class="widget-label">{t('widgets.digitalClock.format24')}</span>
          </div>
        </div>
      </div>

      <!-- Bar Chart -->
      <div class="widget-section">
        <div class="widget-header">
          <div class="widget-icon">📊</div>
          <div class="widget-info">
            <h2>{t('widgets.barChart.title')}</h2>
            <p>{t('widgets.barChart.description')}</p>
          </div>
        </div>

        <!-- Live Screenshots -->
        <div class="subsection-label">{t('widgets.liveExamples')}</div>
