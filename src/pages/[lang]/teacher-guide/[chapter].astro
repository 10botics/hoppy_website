---
import TeacherGuide from '../../../components/TeacherGuide.astro';
import { publishedTeacherGuideChapters } from '../../../data/teacherGuide';
import type { Lang } from '../../../i18n/ui';

export function getStaticPaths() {
  return publishedTeacherGuideChapters.map((chapter) => ({
    params: { lang: 'en', chapter: chapter.slug },
  }));
}

const { lang, chapter } = Astro.params as { lang: Lang; chapter: string };
---

<TeacherGuide lang={lang} chapterSlug={chapter} />
